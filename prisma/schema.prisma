generator client {
    provider = "prisma-client-js"
}


datasource db {
    provider = "postgresql"
}


enum Role {
    ADMIN
    SUB_ADMIN
    CLIENT
    VIEWER
}


model User {
    id      String  @id @default( ulid() )
    name    String
    email   String @unique 

    phone String?

    role Role @default(CLIENT)

    active             Boolean   @default(true)

    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt

    @@map("users")
}


model Material {
    id                 String    @id @default(ulid())
    name               String    @unique
    slug               String    @unique
    description        String?

    autoclavable       Boolean   @default(false)
    maxTemperature     Float?    // En °C
    chemicalResistance Json?

    active             Boolean   @default(true)

    products           Product[]

    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt

    @@map("materials")
}


model Category {
    id              String        @id @default(ulid())
    name            String        @unique

    subCategories   Subcategory[]

    active             Boolean   @default(true)

    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt

    @@map("categories")
}


model Subcategory {
    id          String    @id @default(ulid())
    name        String

    categoryId  String
    category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    active             Boolean   @default(true)

    products    Product[]

    createdAt       DateTime      @default(now())
    updatedAt       DateTime      @updatedAt

    @@map("subcategories")
}


enum AttachmentType {
    IMAGE
    DOCUMENTS
    VIDEOS
    OTHERS
}


model ProductFile {
    id          String  @id @default(ulid())
    url         String
    alt         String?
    isMain      Boolean @default(false)
    order       Int?

    attachmentType AttachmentType? @default(IMAGE)

    productId   String
    product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("product_files")
}


model Product {
    id              String   @id @default(ulid())
    sku             String   @unique
    name            String   @unique
    description     String?

    technical_specs Json?    @default("{}")
    active          Boolean  @default(true)

    subcategoryId String
    subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])

    materialId  String
    material    Material @relation(fields: [materialId], references: [id])

    inKits          KitProduct[]
    inMobileLabs    MobileLabProduct[]
    files           ProductFile[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([technical_specs])

    @@map("products")
}


model KitFile {
    id String @id @default(ulid())

    url         String
    alt         String?
    isMain      Boolean @default(false)
    order       Int?

    attachmentType AttachmentType? @default(IMAGE)

    kitId     String
    kit       Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("kit_files")
}

// --- ESTRUCTURAS COMPUESTAS ---
model Kit {
    id          String    @id @default(ulid())
    sku         String    @unique
    name        String    @unique
    description String?

    active          Boolean  @default(true)

    products    KitProduct[]
    mobileLabs  MobileLabKit[]
    files       KitFile[]

    categoryId  String
    category    KitCategory @relation(fields: [categoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("kits")
}

// Productos dentro de un kit
model KitProduct {
    id        String  @id @default(ulid())
    quantity  Int     @default(1)

    productId String
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    kitId     String
    kit       Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)

    @@unique([productId, kitId])

    @@map("kit_products")
}


model MobileLabFile {
    id String @id @default(ulid())

    url         String
    alt         String?
    isMain      Boolean @default(false)
    order       Int?

    attachmentType AttachmentType? @default(IMAGE)

    mobileLabId     String
    mobileLab       MobileLab     @relation(fields: [mobileLabId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("mobile_lab_files")
}

// --- Estructura de Laboratorio Móvil ---
model MobileLab {
    id          String  @id @default(ulid())
    sku         String  @unique
    name        String  @unique
    description String?
    dimensions  String?

    active      Boolean @default(true)

    products    MobileLabProduct[]
    kits        MobileLabKit[]
    files       MobileLabFile[]

    categoryId  String
    category    LabCategory @relation(fields: [categoryId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("mobile_labs")
}

// Productos dentro de un laboratorio móvil
model MobileLabProduct {
    id          String    @id @default(ulid())
    quantity    Int       @default(1)

    productId   String
    product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

    mobileLabId String
    mobileLab   MobileLab @relation(fields: [mobileLabId], references: [id], onDelete: Cascade)

    @@unique([productId, mobileLabId])

    @@map("mobile_lab_products")
}

// Kits dentro de un laboratorio móvil
model MobileLabKit {
    id          String    @id @default(ulid())
    quantity    Int       @default(1)

    kitId       String
    kit         Kit       @relation(fields: [kitId], references: [id], onDelete: Cascade)

    mobileLabId String
    mobileLab   MobileLab @relation(fields: [mobileLabId], references: [id], onDelete: Cascade)

    @@unique([kitId, mobileLabId])

    @@map("mobile_lab_kits")
}


model KitCategory {
    id        String   @id @default(ulid())
    name      String   @unique
    active    Boolean  @default(true)

    kits      Kit[]    // Relación directa a tus Kits

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("kit_categories")
}


model LabCategory {
    id          String      @id @default(ulid())
    name        String      @unique
    active      Boolean     @default(true)

    mobileLabs  MobileLab[] // Relación directa a tus Laboratorios

    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    @@map("lab_categories")
}
