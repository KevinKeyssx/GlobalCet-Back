{
    "compilerOptions": {
        "types": ["node", "multer"],
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "paths": {
            "@config/*"         : ["./src/config/*"],
            "@common/*"         : ["./src/common/*"],
            "@services/*"       : ["./src/services/*"],
            "@prisma/*"         : ["./src/prisma/*"],
            "@seed/*"           : ["./src/seed/*"],
            "@products/*"       : ["./src/products/*"],
            "@categories/*"     : ["./src/categories/*"],
            "@sub-categories/*"  : ["./src/sub-categories/*"],
            "@materials/*"      : ["./src/materials/*"],
            "@kits/*"           : ["./src/kits/*"],
            "@mobile-labs/*"    : ["./src/mobile-labs/*"],
            "@kit-categories/*" : ["./src/kit-categories/*"],
            "@lab-categories/*" : ["./src/lab-categories/*"],
            "@app/*"            : ["./src/*"],
        }
    }
}
